# =====================================================================
# Stuttgart Archive — environment configuration
# Copy to .env.local and fill in. Every integration degrades to a safe
# MOCK MODE when its keys are absent, so the app builds and runs locally
# with zero external accounts.
# =====================================================================

# --- App ---
NEXT_PUBLIC_APP_URL=http://localhost:3000
# owner/admin email(s), comma-separated — gates /app/admin/quality
ADMIN_EMAILS=

# --- Supabase (auth, database, storage, RLS) ---
# Leave blank to run in mock auth/data mode.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# --- LLM abstraction (OpenAI-compatible) ---
# LLM_PROVIDER: openai | anthropic | mock  (defaults to mock when no key)
LLM_PROVIDER=mock
LLM_API_KEY=
LLM_MODEL=gpt-4o-mini
LLM_BASE_URL=

# --- Email (Resend) ---
# Leave RESEND_API_KEY blank to run EMAIL in mock mode (logs to console + emails table).
RESEND_API_KEY=
EMAIL_MOCK_MODE=true
EMAIL_FROM_NOREPLY=Stuttgart Archive <noreply@stuttgartarchive.com>
EMAIL_FROM_SUPPORT=Stuttgart Archive Support <support@stuttgartarchive.com>
EMAIL_FROM_HELLO=Stuttgart Archive <hello@stuttgartarchive.com>
EMAIL_FROM_CONCIERGE=Stuttgart Archive Concierge <concierge@stuttgartarchive.com>
EMAIL_FROM_UPDATES=Stuttgart Archive <updates@stuttgartarchive.com>
FOUNDER_NOTIFICATION_EMAIL=

# --- Stripe (web payments) ---
# Leave STRIPE_SECRET_KEY blank to run payments in mock/test-stub mode.
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=
# Subscription price IDs
STRIPE_PLUS_PRICE_ID=
STRIPE_COLLECTOR_PRICE_ID=
STRIPE_DEALER_PRICE_ID=
# One-time purchase price IDs (per vehicle)
STRIPE_SELLER_PACK_PRICE_ID=
STRIPE_AUCTION_PACK_PRICE_ID=

# --- Mock integrations (Instagram / Meta Ads) ---
# Not used for posting in MVP — placeholders for future OAuth connection.
INSTAGRAM_CLIENT_ID=
INSTAGRAM_CLIENT_SECRET=
META_ADS_APP_ID=
META_ADS_APP_SECRET=

# --- Future App Store in-app purchases ---
APP_STORE_SHARED_SECRET=

# --- Demo photography (real, license-clean photos for demo cars) ---
# Add a FREE key from pexels.com/api (recommended) or unsplash.com/developers and
# the demo fills with real Porsche photos automatically. Leave all blank to use
# the original car illustrations. Set DEMO_PHOTO_SOURCE=loremflickr for no-key
# Creative-Commons demo photos.
PEXELS_API_KEY=
UNSPLASH_ACCESS_KEY=
DEMO_PHOTO_SOURCE=
